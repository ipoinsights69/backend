{
  "name": "ipo-scraper",
  "version": "1.0.0",
  "description": "IPO data scraper and API server",
  "main": "express-server.js",
  "scripts": {
    "start": "node express-server.js",
    "dev": "nodemon express-server.js",
    "start:prod": "NODE_ENV=production node express-server.js",
    "start:pm2": "pm2 start express-server.js --name ipo-api --max-memory-restart 900M",
    "scrape": "node scripts/scrapeIpos.js",
    "scrape:year": "node scripts/scrapeIpos.js",
    "lint": "eslint .",
    "test": "jest",
    "clean-logs": "rm -rf logs/*.log",
    "analyze": "node scripts/analyzePerformance.js",
    "cron": "node scripts/cronManager.js",
    "cron:list": "node scripts/cronManager.js list",
    "cron:start": "node scripts/cronManager.js start",
    "cron:status": "node scripts/cronManager.js status",
    "cron:setup": "node scripts/setupDailyCron.js",
    "cron:now": "node scripts/runCronNow.js",
    "test:browser": "node tests/testBrowserMethods.js",
    "test:cloudflare": "node tests/testCloudflarePages.js",
    "test:cron": "node tests/testCronMode.js",
    "test:cron-xvfb": "scripts/cron_browser_test.sh"
  },
  "keywords": [
    "ipo",
    "scraper",
    "api",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.0.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^24.6.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-real-browser": "^1.4.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
