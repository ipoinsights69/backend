# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ipo_db
MONGO_POOL_SIZE=5
MONGO_TIMEOUT=5000

# Redis Configuration (optional but recommended)
ENABLE_REDIS=true
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# Admin API Security
ADMIN_API_KEY=your_secure_admin_api_key_here

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Scraper Configuration
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY_MS=2000

# Cron Job Configuration
ENABLE_CRON_JOBS=true

# Performance Settings
NODE_OPTIONS="--max-old-space-size=900"
CLUSTER_MODE=true
COMPRESSION_LEVEL=6

# Cache settings (seconds)
API_CACHE_TIME=60
CACHE_CONTROL_MAX_AGE=3600

# Admin API Authentication
ADMIN_API_TOKEN=your-secure-token-here

# API Server configuration
DELAY_BETWEEN_REQUESTS=1000
MAX_CONCURRENT_REQUESTS=3
DATA_DIR=./data

# Resource optimization
DB_POOL_SIZE=10
MEMORY_LIMIT=512

# Cron job settings
ENABLE_CRONS=false
CRON_LOG_DIR=./logs

# API Settings
REVALIDATE_TIME=3600

# Security Settings
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_ADMIN=300

# Cron Settings
ENABLE_CRON=true
CRON_SCHEDULE="* * * * * *"
CRON_YEAR=2025 